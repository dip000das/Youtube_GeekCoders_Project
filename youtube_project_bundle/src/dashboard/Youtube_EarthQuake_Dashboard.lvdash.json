{
  "datasets": [
    {
      "name": "9f105769",
      "displayName": "EarthQuake_Detail",
      "queryLines": [
        "select * from silver.earthquake_data_final;"
      ],
      "catalog": "youtube_dev",
      "schema": "default"
    },
    {
      "name": "49306928",
      "displayName": "EarthQuake_Type",
      "queryLines": [
        "SELECT \r\n",
        "    COUNT(*) AS total_magnitude_bucket, magnitude_bucket\r\n",
        "FROM (\r\n",
        "    SELECT \r\n",
        "        CASE \r\n",
        "            WHEN mag < 2 THEN 'Micro (<2)'\r\n",
        "            WHEN mag BETWEEN 2 AND 3 THEN 'Minor (2-3)'\r\n",
        "            WHEN mag BETWEEN 3 AND 4  THEN 'Light (3-4)'\r\n",
        "            ELSE 'Moderate+ (4+)'\r\n",
        "        END AS magnitude_bucket\r\n",
        "    FROM silver.earthquake_data_final\r\n",
        ")\r\n",
        "GROUP BY magnitude_bucket;"
      ],
      "catalog": "youtube_dev",
      "schema": "default"
    },
    {
      "name": "e69f9490",
      "displayName": "Earthquake_Country",
      "queryLines": [
        "SELECT\r\n",
        "  COUNT(*) AS event_count,\r\n",
        "  get(split(place, ', '), 1) as country\r\n",
        "FROM\r\n",
        "  silver.earthquake_data_final\r\n",
        "WHERE\r\n",
        "  get(split(place, ', '), 1) IS NOT NULL\r\n",
        "GROUP BY\r\n",
        "  country\r\n",
        "ORDER BY\r\n",
        "  event_count DESC;"
      ],
      "catalog": "youtube_dev",
      "schema": "silver"
    }
  ],
